{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "builder-mcp": {
      "command": "builder-mcp",
      "args": [
        "--include-tools=ReadInternalWebsites,InternalCodeSearch,TicketingReadActions,InternalSearch,SkillsTool"
      ]
    },
    "scuderia-control-plane-mcp": {
      "command": "scuderia-control-plane-mcp-server"
    },
    "drawio": {
      "command": "npx",
      "args": ["@next-ai-drawio/mcp-server@latest"]
    },
    "appsec-mcp": {
      "command": "appsec-mcp",
      "args": []
    }
  }
}
