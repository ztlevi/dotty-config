{
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "frontend-slides@frontend-slides": true
  },
  "env": {
    "AWS_PROFILE": "claude-code-DO-NOT-DELETE",
    "AWS_REGION": "us-west-2",
    "CLAUDE_CODE_USE_BEDROCK": "1"
  },
  "extraKnownMarketplaces": {
    "frontend-slides": {
      "source": {
        "repo": "zarazhangrui/frontend-slides",
        "source": "github"
      }
    }
  },
  "model": "us.anthropic.claude-opus-4-7[1m]",
  "permissions": {
    "allow": [
      "Bash(ada profile list *)",
      "Bash(brazil-build)",
      "Bash(brazil-build *)",
      "Bash(brazil-build-tool-exec *)",
      "Bash(bun *)",
      "Bash(cargo *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(gh api *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(git *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(python3 *)",
      "Bash(rg *)",
      "Bash(sleep *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "WebSearch",
      "WebFetch",
      "mcp__scuderia-control-plane-mcp",
      "mcp__builder-mcp",
      "mcp__aws-knowledge"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git remote add *)",
      "Bash(git remote remove *)",
      "Bash(git remote update *)"
    ]
  },
  "statusLine": {
    "command": "npx -y @owloops/claude-powerline@latest --style=minimal --theme=tokyo-night",
    "type": "command"
  },
  "theme": "auto",
  "tui": "fullscreen"
}