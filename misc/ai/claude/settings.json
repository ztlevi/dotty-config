{
  "awsCredentialExport": "\"/home/zhot/.toolbox/bin/claude\" default-credential-export",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_REGION": "us-west-2"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(ada profile list *)",
      "Bash(brazil-build)",
      "Bash(brazil-build *)",
      "Bash(brazil-build-tool-exec *)",
      "Bash(bun *)",
      "Bash(cargo *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(gh api *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(git *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(python3 *)",
      "Bash(rg *)",
      "Bash(sleep *)",
      "Skill(code-review:code-review)",
      "LSP",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "WebSearch",
      "WebFetch",
      "mcp__scuderia-control-plane-mcp",
      "mcp__builder-mcp",
      "mcp__aws-knowledge"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git remote add *)",
      "Bash(git remote remove *)",
      "Bash(git remote update *)"
    ]
  },
  "model": "global.anthropic.claude-opus-4-8[1m]",
  "availableModels": [
    "opus",
    "sonnet"
  ],
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=minimal --theme=light"
  },
  "enabledPlugins": {
    "AmazonBuilderCoreAIAgents-core@aim": true,
    "AmazonBuilderCoreAIAgents-pipeline-assistant@aim": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-slides@frontend-slides": true,
    "gopls-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "planning-with-files@planning-with-files": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "BuilderInsightsAgents-all@aim": true
  },
  "extraKnownMarketplaces": {
    "aim": {
      "source": {
        "source": "directory",
        "path": "/local/home/zhot/.aim/cc-plugins"
      }
    },
    "frontend-slides": {
      "source": {
        "source": "github",
        "repo": "zarazhangrui/frontend-slides"
      }
    },
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "OthmanAdi/planning-with-files"
      }
    }
  },
  "tui": "fullscreen",
  "theme": "auto",
  "planModeModel": "global.anthropic.claude-opus-4-8[1m]"
}
